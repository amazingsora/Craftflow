# Craftflow 環境設定範本
# 複製此檔為 .env 並依本機環境調整

# ── AI 服務位址 ────────────────────────────────────────────────
# Docker 內連主機用 host.docker.internal；直接跑 Python 用 localhost
OLLAMA_BASE=http://host.docker.internal:11434
COMFYUI_BASE=http://host.docker.internal:8188

# ── 模型選擇 ───────────────────────────────────────────────────
# 依 doc/setup_guide.md「步驟 0」的硬體對照表填入
#
# GPU 16GB（RTX 5070 Ti / 4080）← 預設
#   TEXT_MODEL=dolphin-llama3
#   VISION_MODEL=qwen2.5vl:7b
#
# GPU 24GB+（RTX 4090 / 5090）
#   TEXT_MODEL=qwen2.5:14b
#   VISION_MODEL=qwen2.5vl:7b
#
# GPU 12GB（RTX 4070 / 3060）
#   TEXT_MODEL=dolphin-llama3
#   VISION_MODEL=llava:7b
#
# GPU 8GB（RTX 4060 / 3070）
#   TEXT_MODEL=llama3.2:3b
#   VISION_MODEL=llava:7b
#
# 無 GPU 32GB RAM
#   TEXT_MODEL=llama3.2:8b
#   VISION_MODEL=llava:7b
#
# 無 GPU 16GB RAM
#   TEXT_MODEL=llama3.2:3b
#   VISION_MODEL=moondream
TEXT_MODEL=dolphin-llama3
VISION_MODEL=qwen2.5vl:7b
