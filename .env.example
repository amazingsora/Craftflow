# Craftflow 環境設定範本
# 複製此檔為 .env 並依本機環境調整

# ── AI 服務位址 ────────────────────────────────────────────────
# Docker 內連主機用 host.docker.internal；直接跑 Python 用 localhost
OLLAMA_BASE=http://host.docker.internal:11434
COMFYUI_BASE=http://host.docker.internal:8188

# ── 模型選擇 ───────────────────────────────────────────────────
# 依 doc/setup_guide.md「步驟 0」的硬體對照表填入
#
# GPU 16GB（RTX 5070 Ti / 4080）← 預設
#   TEXT_MODEL=dolphin-llama3
#   VISION_MODEL=qwen2.5vl:7b
#
# GPU 24GB+（RTX 4090 / 5090）
#   TEXT_MODEL=qwen2.5:14b
#   VISION_MODEL=qwen2.5vl:7b
#
# GPU 12GB（RTX 4070 / 3060）
#   TEXT_MODEL=dolphin-llama3
#   VISION_MODEL=llava:7b
#
# GPU 8GB（RTX 4060 / 3070）
#   TEXT_MODEL=llama3.2:3b
#   VISION_MODEL=llava:7b
#
# 無 GPU 32GB RAM
#   TEXT_MODEL=llama3.2:8b
#   VISION_MODEL=llava:7b
#
# 無 GPU 16GB RAM
#   TEXT_MODEL=llama3.2:3b
#   VISION_MODEL=moondream
TEXT_MODEL=dolphin-llama3
VISION_MODEL=qwen2.5vl:7b

# ── LoRA 訓練設定 ───────────────────────────────────────────────
# TRAINING_RUNNER_MODE: local（本機 subprocess）| remote（Docker 模式，需 host agent）
TRAINING_RUNNER_MODE=local
# kohya_ss 安裝目錄（local 模式使用）
KOHYA_PATH=C:\kohya_ss
# 訓練圖片上傳暫存目錄（後端本地路徑）
TRAINING_IMAGES_DIR=F:\wk\Craftflow\data\training_images
# ComfyUI LoRA 目錄（訓練完成後自動複製）
COMFYUI_LORAS_DIR=F:\AI\ComfyUI\models\loras

# ── Personal Style Preset（個人風格預設，預設關閉）──────────────────────────
# 啟用後，角色生圖時會自動附加指定畫風標籤與使用個人負向提示詞
# 適合固定使用特定畫風（如 Blue Archive / Project Sekai）的個人用戶
#
# PERSONAL_STYLE_ENABLED=false
# PERSONAL_STYLE_EXTRA_TAGS=Blue Archive style, anime game illustration, clean lineart, soft shading, large expressive eyes, delicate face, pale skin, light blush, pastel tone, crisp edges, bright highlights, high detail
#
# PERSONAL_NEGATIVE_ENABLED=false
# PERSONAL_NEGATIVE=lowres, bad quality, worst quality, sketch, rough lineart, photorealistic, 3d, realistic, heavy rendering, oily skin, blurry face, deformed hands, extra fingers, bad anatomy, watermark, signature, text
